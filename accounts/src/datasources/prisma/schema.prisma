generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  username       String   @id
  name           String
  role           String   @default("Guest")
  description    String
  lastActiveTime DateTime @default(now())
  isLoggedIn     Boolean  @default(false)
}
